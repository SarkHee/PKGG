generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clan {
  id                Int          @id @default(autoincrement())
  name              String       @unique
  leader            String
  description       String?
  announcement      String?
  memberCount       Int
  avgScore          Int?
  mainStyle         String?
  pubgClanId        String?      @unique
  pubgClanTag       String?
  pubgClanLevel     Int?
  pubgMemberCount   Int?
  lastSynced        DateTime?
  region            String?
  isKorean          Boolean?
  shardDistribution String?
  members           ClanMember[]
}

model ClanMember {
  id             Int               @id @default(autoincrement())
  nickname       String
  score          Int
  style          String
  avgDamage      Float
  avgKills       Float             @default(0)
  avgAssists     Float             @default(0)
  avgSurviveTime Float             @default(0)
  winRate        Float             @default(0)
  top10Rate      Float             @default(0)
  clanId         Int?
  pubgClanId     String?
  pubgPlayerId   String?
  pubgShardId    String?
  lastUpdated    DateTime          @default(now())
  clan           Clan?             @relation(fields: [clanId], references: [id])
  matches        PlayerMatch[]
  modeStats      PlayerModeStats[]
}

model PlayerMatch {
  id           Int        @id @default(autoincrement())
  clanMemberId Int
  matchId      String
  mode         String
  mapName      String?
  placement    Int
  kills        Int
  assists      Int
  damage       Float
  surviveTime  Float
  createdAt    DateTime   @default(now())
  clanMember   ClanMember @relation(fields: [clanMemberId], references: [id])
}

model PlayerModeStats {
  id           Int        @id @default(autoincrement())
  clanMemberId Int
  mode         String
  matches      Int
  wins         Int
  top10s       Int
  avgDamage    Float
  avgKills     Float
  avgAssists   Float
  winRate      Float
  top10Rate    Float
  clanMember   ClanMember @relation(fields: [clanMemberId], references: [id])
}

model ForumCategory {
  id          String      @id
  name        String
  description String
  icon        String
  color       String
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  posts       ForumPost[]
}

model ForumPost {
  id         Int           @id @default(autoincrement())
  title      String
  content    String
  preview    String?
  author     String
  categoryId String
  views      Int           @default(0)
  likes      Int           @default(0)
  isPinned   Boolean       @default(false)
  isLocked   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  password   String?
  likedBy    ForumLike[]
  category   ForumCategory @relation(fields: [categoryId], references: [id])
  replies    ForumReply[]
}

model ForumReply {
  id        Int          @id @default(autoincrement())
  content   String
  author    String
  postId    Int
  parentId  Int?
  likes     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  password  String?
  parent    ForumReply?  @relation("ReplyToReply", fields: [parentId], references: [id])
  children  ForumReply[] @relation("ReplyToReply")
  post      ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ForumLike {
  id        Int       @id @default(autoincrement())
  postId    Int
  author    String
  createdAt DateTime  @default(now())
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, author])
}

model ForumUser {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  violationCount   Int       @default(0)
  lastViolation    DateTime?
  violationType    String?
  violationContent String?
  isBanned         Boolean   @default(false)
  banReason        String?
  banUntil         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("forum_users")
}

model PubgNews {
  id          Int       @id @default(autoincrement())
  title       String
  link        String    @unique
  url         String?
  category    String?
  publishedAt DateTime?
  publishDate DateTime?
  imageUrl    String?
  summary     String?
  source      String    @default("PUBG_OFFICIAL")
  views       Int       @default(0)
  isActive    Boolean   @default(true)
  priority    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pubg_news")
}

model WeaponTestResult {
  id              Int      @id @default(autoincrement())
  sessionId       String   @unique
  pubgPlayerId    String?
  nickname        String?
  platform        String?  @default("steam")
  resultType      String
  resultName      String
  similarityScore Float
  surveyVector    Json
  createdAt       DateTime @default(now())

  @@map("weapon_test_results")
}

model RankingUpdateLog {
  id           Int      @id @default(autoincrement())
  updateType   String
  updateTime   DateTime
  status       String
  updatedCount Int      @default(0)
  errorMessage String?
  details      String?
  createdAt    DateTime @default(now())

  @@map("ranking_update_logs")
}

model Notice {
  id        Int       @id @default(autoincrement())
  title     String
  content   String
  summary   String?
  type      String
  priority  String    @default("NORMAL")
  isActive  Boolean   @default(true)
  isPinned  Boolean   @default(false)
  showUntil DateTime?
  author    String    @default("관리자")
  views     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("notices")
}

model PlayerCache {
  id             Int      @id @default(autoincrement())
  nickname       String
  pubgShardId    String   @default("steam")
  pubgPlayerId   String?
  score          Int      @default(0)
  style          String   @default("")
  avgDamage      Float    @default(0)
  avgKills       Float    @default(0)
  avgAssists     Float    @default(0)
  avgSurviveTime Float    @default(0)
  winRate        Float    @default(0)
  top10Rate      Float    @default(0)
  lastUpdated    DateTime @default(now())

  @@unique([nickname, pubgShardId])
  @@map("player_cache")
}

model PlayerAnalysis {
  id               Int      @id @default(autoincrement())
  playerNickname   String
  playerServer     String
  playStyle        String
  playstyleScore   Float
  strengths        String
  weaknesses       String
  killDeathRatio   Float
  damagePerGame    Float
  survivalRate     Float
  aggressionIndex  Float
  consistencyIndex Float
  recommendations  String
  trainingPlan     String
  lastAnalyzed     DateTime @default(now())

  @@unique([playerNickname, playerServer])
  @@map("player_analyses")
}

model CoachingTip {
  id          Int      @id @default(autoincrement())
  category    String
  playStyle   String
  title       String
  description String
  difficulty  String
  priority    Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("coaching_tips")
}

model User {
  id            Int      @id @default(autoincrement())
  steamId       String   @unique
  pubgNickname  String?
  pubgAccountId String?
  clanId        Int?
  role          String   @default("user")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model TrainingSession {
  id             Int       @id @default(autoincrement())
  playerNickname String
  playerServer   String
  sessionType    String
  targetSkill    String
  duration       Int
  exercises      String
  goals          String
  status         String    @default("PENDING")
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@map("training_sessions")
}

// 플레이어 스탯 스냅샷 — 성장 추적용 히스토리
model PlayerStatSnapshot {
  id             Int      @id @default(autoincrement())
  nickname       String
  pubgShardId    String   @default("steam")
  score          Int      @default(0)
  avgDamage      Float    @default(0)
  avgKills       Float    @default(0)
  avgAssists     Float    @default(0)
  avgSurviveTime Float    @default(0)
  winRate        Float    @default(0)
  top10Rate      Float    @default(0)
  capturedAt     DateTime @default(now())

  @@index([nickname, pubgShardId, capturedAt])
  @@map("player_stat_snapshots")
}

// 클랜 내전 기록
model ClanWar {
  id          Int      @id @default(autoincrement())
  clanA       String
  clanB       String
  scoreA      Int      @default(0)
  scoreB      Int      @default(0)
  map         String   @default("")
  mode        String   @default("squad-fpp")
  note        String   @default("")
  password    String   @default("")
  playedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  players     ClanWarPlayer[]

  @@index([clanA, clanB])
  @@map("clan_wars")
}

model ClanWarPlayer {
  id        Int      @id @default(autoincrement())
  warId     Int
  war       ClanWar  @relation(fields: [warId], references: [id], onDelete: Cascade)
  nickname  String
  team      String   // 'A' | 'B'
  kills     Int      @default(0)
  damage    Int      @default(0)
  survived  Boolean  @default(false)

  @@index([warId])
  @@map("clan_war_players")
}

// 플레이어 리뷰
model PlayerReview {
  id          Int      @id @default(autoincrement())
  targetNick  String
  shard       String   @default("steam")
  authorNick  String
  rating      Int                      // 1~5
  teamplay    Int      @default(3)     // 1~5
  communication Int    @default(3)     // 1~5
  comment     String   @default("")
  password    String   @default("")
  createdAt   DateTime @default(now())

  @@index([targetNick, shard])
  @@map("player_reviews")
}
